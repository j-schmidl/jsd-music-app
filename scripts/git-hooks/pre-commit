#!/bin/sh
# Pre-commit gate for the metronome feature.
#
# When a commit touches the metronome feature — or anything it shares (tempo /
# onset logic, the audio fixtures, the nav, build/test config) — run the unit
# suite, which includes the real-audio BPM validation (decodes the WAV fixtures
# and asserts the detected tempo). A change can't land with the beat detection
# broken. Other commits skip straight through.
#
# This replaces a GitHub Actions workflow: pushing files under .github/workflows
# needs a token with the `workflow` OAuth scope, which the local credential
# doesn't have. A hook needs no special scope.
#
# Bypass in a pinch with:  git commit --no-verify

# Paths that make up / affect the metronome feature.
PATTERN='^(src/lib/(bpm|onset)\.|src/hooks/use(Metronome|BpmDetector)\.|src/components/(Metronome|BottomNav)\.|src/App\.tsx|tests/fixtures/audio/|tests/e2e/metronome\.spec\.|package\.json|tsconfig.*\.json)'

changed=$(git diff --cached --name-only --diff-filter=ACM | grep -E "$PATTERN")
if [ -z "$changed" ]; then
  exit 0
fi

echo "▶ metronome files staged — running unit tests…"

# Pick a Node new enough for vite 8 / vitest 4. The machine's default node is
# broken and nvm's default is too old, so prefer nvm's Node 22 when available.
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  # shellcheck disable=SC1091
  . "$NVM_DIR/nvm.sh" >/dev/null 2>&1
  nvm use 22 >/dev/null 2>&1 || nvm use --lts >/dev/null 2>&1
fi

if ! npm run test:run; then
  echo "✗ unit tests failed — commit aborted. (Bypass with: git commit --no-verify)"
  exit 1
fi
echo "✓ metronome tests passed"
exit 0
